\name{roffeR-package}
\alias{roffeR-package}
\docType{package}
\title{Personal R startup helpers}
\description{
Small helpers for interactive R sessions.
}
\details{
\code{roffeR} is a tiny personal package for interactive work. It sets a
preferred CRAN mirror on attach, provides a safer \code{q()} default that does
not ask about saving the workspace image, and keeps a few convenience wrappers
in one place.
}
\author{
Rolf Mblindgren
}
\keyword{package}

